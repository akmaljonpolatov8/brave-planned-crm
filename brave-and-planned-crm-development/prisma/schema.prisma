generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           Int        @id @default(autoincrement())
  username     String     @unique
  fullName     String     @map("full_name")
  passwordHash String     @map("password_hash")
  role         String     // owner, manager, teacher
  isActive     Boolean    @default(true) @map("is_active")
  createdAt    DateTime   @default(now()) @map("created_at")

  // Relations
  teacher      Teacher?
  transfers    Transfer[] @relation("TransferDoneBy")

  @@map("users")
}

model Teacher {
  id           Int      @id @default(autoincrement())
  fullName     String   @map("full_name")
  phone        String?
  isActive     Boolean  @default(true) @map("is_active")
  userId       Int?     @unique @map("user_id")
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  groups       Group[]

  @@map("teachers")
}

model Group {
  id           Int      @id @default(autoincrement())
  name         String
  teacherId    Int?     @map("teacher_id")
  scheduleDays String?  @map("schedule_days")
  startTime    String?  @map("start_time")
  endTime      String?  @map("end_time")
  monthlyFee   Int      @default(0) @map("monthly_fee")
  capacity     Int      @default(20)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  teacher      Teacher? @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  students     GroupStudent[]
  attendance   Attendance[]
  payments     Payment[]
  transfersFrom Transfer[] @relation("TransferFrom")
  transfersTo   Transfer[] @relation("TransferTo")

  @@map("groups")
}

model Student {
  id           Int      @id @default(autoincrement())
  fullName     String   @map("full_name")
  phone        String?
  parentPhone  String?  @map("parent_phone")
  parentName   String?  @map("parent_name")
  status       String   @default("active") // active, inactive, frozen
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  groups       GroupStudent[]
  attendance   Attendance[]
  payments     Payment[]
  smsLogs      SmsLog[]
  transfers    Transfer[]

  @@map("students")
}

model GroupStudent {
  id         Int      @id @default(autoincrement())
  groupId    Int      @map("group_id")
  studentId  Int      @map("student_id")
  joinedAt   DateTime @default(now()) @map("joined_at")
  leftAt     DateTime? @map("left_at")
  isActive   Boolean  @default(true) @map("is_active")

  // Relations
  group      Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([groupId, studentId])
  @@map("group_students")
}

model Attendance {
  id         Int      @id @default(autoincrement())
  groupId    Int      @map("group_id")
  studentId  Int      @map("student_id")
  date       String
  status     String   // present, absent, late, excused
  note       String?
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  group      Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([groupId, studentId, date])
  @@map("attendance")
}

model Payment {
  id         Int       @id @default(autoincrement())
  studentId  Int       @map("student_id")
  groupId    Int       @map("group_id")
  month      String
  amount     Int       @default(0)
  paid       Boolean   @default(false)
  paidAt     DateTime? @map("paid_at")
  note       String?
  createdAt  DateTime  @default(now()) @map("created_at")

  // Relations
  student    Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  group      Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([studentId, groupId, month])
  @@map("payments")
}

model Transfer {
  id           Int      @id @default(autoincrement())
  studentId    Int      @map("student_id")
  fromGroupId  Int      @map("from_group_id")
  toGroupId    Int      @map("to_group_id")
  transferDate DateTime @default(now()) @map("transfer_date")
  note         String?
  doneBy       Int?     @map("done_by")

  // Relations
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  fromGroup    Group    @relation("TransferFrom", fields: [fromGroupId], references: [id])
  toGroup      Group    @relation("TransferTo", fields: [toGroupId], references: [id])
  doneByUser   User?    @relation("TransferDoneBy", fields: [doneBy], references: [id])

  @@map("transfers")
}

model SmsLog {
  id         Int      @id @default(autoincrement())
  studentId  Int?     @map("student_id")
  phone      String
  message    String
  month      String?
  status     String   @default("pending")
  sentAt     DateTime @default(now()) @map("sent_at")

  // Relations
  student    Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)

  @@map("sms_logs")
}
