generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  fullName     String
  username     String        @unique
  passwordHash String
  role         String
  isActive     Boolean       @default(true)
  activities   ActivityLog[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Student {
  id             String          @id @default(cuid())
  firstName      String
  lastName       String
  phone          String
  parentPhone    String
  birthDate      DateTime?
  status         String          @default("ACTIVE")
  notes          String?
  groupLinks     GroupStudent[]
  attendance     Attendance[]
  payments       Payment[]
  smsLogs        SmsLog[]
  transfers      Transfer[]      @relation("StudentTransfers")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([firstName, lastName])
  @@index([status])
}

model Teacher {
  id          String    @id @default(cuid())
  firstName   String
  lastName    String
  phone       String
  specialty   String?
  groups      Group[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Group {
  id             String         @id @default(cuid())
  name           String
  schedule       String
  monthlyFee     Int
  startDate      DateTime
  isActive       Boolean        @default(true)
  teacherId      String
  teacher        Teacher        @relation(fields: [teacherId], references: [id], onDelete: Restrict)
  students       GroupStudent[]
  attendance     Attendance[]
  payments       Payment[]
  transferFrom   Transfer[]     @relation("TransferFromGroup")
  transferTo     Transfer[]     @relation("TransferToGroup")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([teacherId])
  @@index([isActive])
}

model GroupStudent {
  id         String   @id @default(cuid())
  groupId     String
  studentId   String
  joinedAt    DateTime @default(now())
  leftAt      DateTime?
  isActive    Boolean  @default(true)
  group       Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@index([studentId])
  @@index([isActive])
}

model Attendance {
  id          String           @id @default(cuid())
  groupId      String
  studentId    String
  date         DateTime
  status       String
  note         String?
  group        Group            @relation(fields: [groupId], references: [id], onDelete: Cascade)
  student      Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdAt    DateTime         @default(now())

  @@unique([groupId, studentId, date])
  @@index([groupId, date])
  @@index([studentId, date])
}

model Payment {
  id             String         @id @default(cuid())
  studentId       String
  groupId         String
  month           String
  amountDue       Int
  amountPaid      Int            @default(0)
  dueDate         DateTime
  paidAt          DateTime?
  status          String         @default("UNPAID")
  note            String?
  student         Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  group           Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([studentId, groupId, month])
  @@index([month, status])
  @@index([groupId])
}

model SmsLog {
  id             String     @id @default(cuid())
  studentId       String
  phone           String
  message         String
  month           String
  provider        String
  status          String
  responsePayload String?
  sentAt          DateTime?
  createdAt       DateTime   @default(now())
  student         Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, month])
}

model Transfer {
  id                String    @id @default(cuid())
  studentId          String
  fromGroupId        String
  toGroupId          String
  transferDate       DateTime @default(now())
  proratedAmount     Int
  note               String?
  student            Student  @relation("StudentTransfers", fields: [studentId], references: [id], onDelete: Cascade)
  fromGroup          Group    @relation("TransferFromGroup", fields: [fromGroupId], references: [id], onDelete: Restrict)
  toGroup            Group    @relation("TransferToGroup", fields: [toGroupId], references: [id], onDelete: Restrict)

  @@index([studentId, transferDate])
}

model ActivityLog {
  id          String   @id @default(cuid())
  userId       String
  action       String
  module       String
  entityId     String?
  description  String
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([module, createdAt])
}
