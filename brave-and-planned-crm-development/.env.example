# Neon PostgreSQL
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# JWT
JWT_SECRET="your-secret-key-change-in-production"

# TextUP SMS API
TEXTUP_EMAIL="your@email.com"
TEXTUP_PASSWORD="your_password"
TEXTUP_USER_ID="your-user-uuid-from-login-response"
TEXTUP_NICKNAME_ID="your-nickname-uuid-from-nick-names-endpoint"

# Server
PORT=5000
NODE_ENV=production
