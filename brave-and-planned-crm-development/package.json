{
  "name": "brave-and-planet-crm",
  "version": "1.0.0",
  "private": true,
  "description": "Brave and Planet ta'lim markazi uchun CRM",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "node ./node_modules/vite/bin/vite.js --config vite.config.ts",
    "dev:server": "node --watch server/index.js",
    "build": "npm run build:client",
    "build:client": "node ./node_modules/vite/bin/vite.js build --config vite.config.ts",
    "start": "node server/index.js",
    "db:init": "node server/db/init.js",
    "db:seed": "node server/db/seed.js",
    "import:excel": "node server/scripts/import-workbook.js",
    "prisma:seed": "ts-node --esm prisma/seed.ts"
  },
  "prisma": {
    "seed": "ts-node --esm prisma/seed.ts"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "vite": "^5.4.0"
  }
}
